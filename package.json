{
  "name": "blammytv",
  "version": "0.6.20",
  "private": true,
  "description": "Self-contained desktop IPTV/VOD client (Xtream Codes + AIOStreams/debrid).",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "pnpm --filter @blammytv/app dev",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r --if-present test",
    "lint": "eslint ."
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.5.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.6.0",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.61.1"
  }
}
