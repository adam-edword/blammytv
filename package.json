{
  "name": "blammytv",
  "version": "0.1.0",
  "private": true,
  "description": "react-based iptv client (xtream codes + debrid). thin clients, backend-owned config.",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "pnpm --filter @blammytv/app dev",
    "dev:all": "concurrently -n server,app -c blue,green \"pnpm --filter @blammytv/server dev\" \"pnpm --filter @blammytv/app dev\"",
    "server": "pnpm --filter @blammytv/server dev",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r --if-present test",
    "lint": "eslint ."
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "concurrently": "^10.0.3",
    "eslint": "^10.5.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.6.0",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.61.1"
  }
}
