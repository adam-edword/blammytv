{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "BlammyTV",
  "version": "0.6.0",
  "identifier": "com.blammytv.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "title": "BlammyTV",
        "width": 1280,
        "height": 800,
        "minWidth": 1000,
        "minHeight": 680,
        "resizable": true,
        "fullscreen": false,
        "transparent": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/adam-edword/blammytv/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDE2M0VCRDUxQjRFRTMyMzIKUldReU11NjBVYjArRnV2eHphSzhMaTM0dWFiU2pHd1lON2M4QUUyajBCWWtkWTVkd1pHRFMvbmkK"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
