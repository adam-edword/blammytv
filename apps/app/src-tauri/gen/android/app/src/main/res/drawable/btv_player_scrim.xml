<?xml version="1.0" encoding="utf-8"?>
<!-- Bottom scrim behind the player chrome. Mirrors the Windows .theater-bar:
     linear-gradient(to top, rgba(0,0,0,.92) 0%, rgba(0,0,0,.72) 45%, transparent).
     angle=90 → bottom-to-top: startColor is the bottom. -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
  <gradient
      android:type="linear"
      android:angle="90"
      android:startColor="#EB000000"
      android:centerColor="#B8000000"
      android:endColor="#00000000" />
</shape>
