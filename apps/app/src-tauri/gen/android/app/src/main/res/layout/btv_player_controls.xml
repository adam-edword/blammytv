<?xml version="1.0" encoding="utf-8"?>
<!-- Custom Media3 controller layout — mirrors the Windows VOD theater chrome.
     Media3 wires the views with @id/exo_* IDs (play/pause, progress, position,
     duration, rew, ffwd); the btv_* views are populated by MainActivity from the
     forwarded meta. Sized up for a 10-foot TV. -->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

  <LinearLayout
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_gravity="bottom"
      android:orientation="vertical"
      android:background="@drawable/btv_player_scrim"
      android:paddingStart="48dp"
      android:paddingEnd="48dp"
      android:paddingTop="128dp"
      android:paddingBottom="40dp">

    <!-- Clearlogo (wide, transparent) — loaded via Coil. -->
    <ImageView
        android:id="@+id/btv_logo"
        android:layout_width="wrap_content"
        android:layout_height="68dp"
        android:maxWidth="380dp"
        android:adjustViewBounds="true"
        android:scaleType="fitStart"
        android:layout_marginBottom="16dp"
        android:contentDescription="@null"
        android:visibility="gone" />

    <!-- Meta line: 2020 · Series · 1080p ⚡ (BlammyTV red). -->
    <TextView
        android:id="@+id/btv_meta"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:maxLines="1"
        android:ellipsize="end"
        android:textColor="#C22727"
        android:textStyle="bold"
        android:textSize="17sp"
        android:letterSpacing="0.01" />

    <!-- Title. -->
    <TextView
        android:id="@+id/btv_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:maxLines="2"
        android:ellipsize="end"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        android:textSize="32sp" />

    <!-- Subtitle: Season 0 · Episode 1 (or synopsis). -->
    <TextView
        android:id="@+id/btv_subtitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:maxLines="2"
        android:ellipsize="end"
        android:textColor="#B3FFFFFF"
        android:textSize="19sp"
        android:visibility="gone" />

    <!-- Scrubber row: position · timeline · duration. -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:orientation="horizontal"
        android:gravity="center_vertical">

      <TextView
          android:id="@id/exo_position"
          android:layout_width="wrap_content"
          android:layout_height="wrap_content"
          android:textColor="#FFFFFF"
          android:textSize="15sp"
          android:includeFontPadding="false" />

      <androidx.media3.ui.DefaultTimeBar
          android:id="@id/exo_progress"
          android:layout_width="0dp"
          android:layout_height="28dp"
          android:layout_weight="1"
          android:layout_marginStart="16dp"
          android:layout_marginEnd="16dp"
          app:bar_height="3dp"
          app:scrubber_enabled_size="15dp"
          app:scrubber_dragged_size="19dp"
          app:played_color="#C22727"
          app:scrubber_color="#C22727"
          app:buffered_color="#66FFFFFF"
          app:unplayed_color="#33FFFFFF" />

      <TextView
          android:id="@id/exo_duration"
          android:layout_width="wrap_content"
          android:layout_height="wrap_content"
          android:textColor="#FFFFFF"
          android:textSize="15sp"
          android:includeFontPadding="false" />
    </LinearLayout>

    <!-- Transport row: rew · play/pause · ffwd on the left, speed on the right. -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp">

      <LinearLayout
          android:layout_width="wrap_content"
          android:layout_height="wrap_content"
          android:layout_alignParentStart="true"
          android:orientation="horizontal"
          android:gravity="center_vertical">

        <ImageButton
            android:id="@id/exo_rew"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:padding="12dp"
            android:scaleType="fitCenter"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:tint="#FFFFFF"
            android:src="@drawable/exo_styled_controls_rewind"
            android:contentDescription="Rewind 10 seconds" />

        <ImageButton
            android:id="@id/exo_play_pause"
            android:layout_width="76dp"
            android:layout_height="76dp"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="8dp"
            android:padding="12dp"
            android:scaleType="fitCenter"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:tint="#FFFFFF"
            android:src="@drawable/exo_styled_controls_play"
            android:contentDescription="Play/Pause" />

        <ImageButton
            android:id="@id/exo_ffwd"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:padding="12dp"
            android:scaleType="fitCenter"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:tint="#FFFFFF"
            android:src="@drawable/exo_styled_controls_fastforward"
            android:contentDescription="Forward 10 seconds" />
      </LinearLayout>

      <Button
          android:id="@+id/btv_speed"
          android:layout_width="wrap_content"
          android:layout_height="wrap_content"
          android:layout_alignParentEnd="true"
          android:layout_centerVertical="true"
          android:minWidth="0dp"
          android:minHeight="0dp"
          android:paddingStart="16dp"
          android:paddingEnd="16dp"
          android:paddingTop="10dp"
          android:paddingBottom="10dp"
          android:background="?android:attr/selectableItemBackground"
          android:textColor="#FFFFFF"
          android:textSize="18sp"
          android:textStyle="bold"
          android:textAllCaps="false"
          android:text="1×" />
    </RelativeLayout>
  </LinearLayout>
</FrameLayout>
