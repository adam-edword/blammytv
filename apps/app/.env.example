# Copy this file to `.env.local` (which is gitignored) to point the app at a
# backend during development:
#
#   Windows (PowerShell):  copy .env.example .env.local
#   macOS / Linux:         cp .env.example .env.local
#
# With this set, the app pulls its config from the backend's /config endpoint.
# Leave it unset (no .env.local) to run in demo mode against the bundled seed.

VITE_API_URL=http://localhost:8787
