# Copy to `.env` (gitignored) for local dev. The server loads it automatically.

# Port the backend listens on (default 8787).
# PORT=8787

# AIOStreams connection for VOD (movies + shows). This is the single Stremio
# manifest URL from your AIOStreams instance — it embeds your private config
# (debrid keys etc.), so it is a SECRET: keep it here, never commit it.
# Without it, the Stream tab falls back to the bundled demo catalog.
BLAMMY_AIOSTREAMS_URL=https://your-aiostreams-host/stremio/<config>/manifest.json
