node_modules/
dist/
dist-ssr/
*.local

# build output
**/dist/
**/.vite/

# tauri (added later)
**/src-tauri/target/

# editor / os
.DS_Store
.vscode/*
!.vscode/extensions.json
*.log

# secrets / local env (never commit; .env.example is the tracked template)
.env
.env.*
!.env.example

# libmpv runtime DLL (place locally for tauri build; not committed). The Windows
# DLL also gets copied into the Android bundle assets and can linger at the repo
# root — it's a Windows binary, never commit it anywhere.
**/src-tauri/*.dll
**/libmpv-2.dll

# --- Never commit: source credentials + large native binaries ---
# Server runtime data holds configured IPTV/debrid source credentials.
apps/server/data/
# Desktop runtime + vendored/built native binaries (too large for git / GitHub).
apps/desktop/bin/
apps/desktop/native/mpv/build/
apps/desktop/native/mpv/vendor/*.dll
apps/desktop/native/mpv/vendor/lib/
